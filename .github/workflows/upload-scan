# ============================================================
# VERACODE POLICY SCAN — GitHub Actions
# Sube el artefacto a Veracode Platform y ejecuta un
# Policy Scan completo. Crea el perfil de aplicación
# automáticamente si no existe.
# Los resultados se visualizan en:
# Veracode Platform → My Portfolio → Applications
# ============================================================

name: Veracode Policy Scan

# ─────────────────────────────────────────────
# TRIGGERS — Cuándo se ejecuta este workflow
# Recomendado: nightly build o release
# No ejecutar en cada push — es un scan pesado
# ─────────────────────────────────────────────
on:
  schedule:
    - cron: '0 2 * * 1'              # Lunes a las 2AM (nightly semanal)
  workflow_dispatch:                  # Ejecución manual desde GitHub Actions
    inputs:
      app_name:
        description: 'Nombre de la aplicación en Veracode Platform'
        required: false
        default: 'Verademo-GitHub'

jobs:

  # ══════════════════════════════════════════
  # JOB 1: BUILD
  # Compila el código Java con Maven
  # y genera el artefacto .war
  # ══════════════════════════════════════════
  build:
    runs-on: ubuntu-latest

    steps:
      # Paso 1: Clona el repositorio
      - name: Checkout código
        uses: actions/checkout@v4

      # Paso 2: Instala Java 11
      - name: Set up JDK 11
        uses: actions/setup-java@v4
        with:
          java-version: '11'
          distribution: 'temurin'

      # Paso 3: Compila con Maven
      - name: Build con Maven
        working-directory: ./app
        run: mvn -B clean package --file pom.xml -DskipTests

      # Paso 4: Sube el .war como artefacto
      - name: Subir artefacto
        uses: actions/upload-artifact@v4
        with:
          name: verademo-policy-artifact
          path: ./app/target/*.war

  # ══════════════════════════════════════════
  # JOB 2: VERACODE POLICY SCAN
  # Sube el artefacto a Veracode Platform
  # Crea el perfil si no existe (createprofile: true)
  # Ejecuta el Policy Scan completo
  # ══════════════════════════════════════════
  veracode-policy-scan:
    needs: build
    runs-on: ubuntu-latest

    steps:
      # Paso 1: Descarga el artefacto del job build
      - name: Descargar artefacto
        uses: actions/download-artifact@v4
        with:
          name: verademo-policy-artifact

      # Paso 2: Verificar artefacto descargado
      - name: Listar archivos
        run: ls -la

      # Paso 3: Ejecuta el Policy Scan en Veracode Platform
      # createprofile: true → crea el perfil automáticamente si no existe
      # appname → nombre del perfil en Veracode Platform
      # version → versión del scan (usa el número de run de GitHub)
      # deleteincompletescan → elimina scans incompletos anteriores
      # criticality → criticidad del negocio (VeryHigh, High, Medium, Low, VeryLow)
      #   determina qué política se asigna automáticamente al perfil
      - name: Veracode Upload and Scan
        uses: veracode/uploadandscan-action@v1
        with:
          appname: 'Verademo-GitHub'        # Nombre del perfil en Veracode Platform
                                            # Si no existe, se crea automáticamente
          createprofile: true               # true = crear perfil si no existe
          filepath: '*.war'                 # Ruta del artefacto a escanear
          vid: ${{ secrets.VID }}           # API ID de Veracode
          vkey: ${{ secrets.VKEY }}         # API Secret Key de Veracode
          version: '${{ github.run_number }}'  # Versión del scan
          criticality: 'High'              # Criticidad: VeryHigh, High, Medium,
                                           # Low, VeryLow
                                           # Determina la política asignada al perfil
          deleteincompletescan: true        # Elimina scans anteriores incompletos
                                           # para evitar conflictos
          # sandboxname: 'GitHub-CI'        # Descomentar para usar sandbox
          # createsandbox: true             # en lugar del perfil de producción
